# =============================================================================
# Launch Inertia - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# ── Environment ─────────────────────────────────────────
# APP_ENV values: local, development, testing, staging, production
APP_ENV=local
DJANGO_ENV=development
DEBUG=True

# ── Security ────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-in-production

# Comma-separated
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8844,http://localhost:3344

# ── Database (PostgreSQL) ───────────────────────────────
DB_NAME=launch_inertia
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=0

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1

# ── Email (AWS SES in production) ──────────────────────
# In development, emails go to console by default
DEFAULT_FROM_EMAIL=noreply@launch.app
AWS_SES_REGION_NAME=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Google OAuth (django-allauth) ──────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=

# ── Stripe / dj-stripe ─────────────────────────────────
STRIPE_LIVE_MODE=False
STRIPE_TEST_SECRET_KEY=sk_test_your_key
STRIPE_TEST_PUBLIC_KEY=pk_test_your_key
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_PUBLIC_KEY=
DJSTRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ── Vite Dev Server ────────────────────────────────────
VITE_DEV_URL=http://localhost:3344

# ── Landing Runtime Migration ──────────────────────────
# Legacy JSON landing fallback should stay enabled in dev/test while campaigns
# are being synced to CapturePage. In production, prefer False.
LANDING_JSON_FALLBACK_ENABLED=True
# Outbox health thresholds
LEAD_OUTBOX_FAILED_THRESHOLD=5
LEAD_OUTBOX_PENDING_THRESHOLD=10
LEAD_OUTBOX_PENDING_MAX_AGE_MINUTES=30
LEAD_OUTBOX_N8N_SLO_MINUTES=10
LEAD_OUTBOX_META_CAPI_SLO_MINUTES=15

# ── Sentry (production only) ───────────────────────────
# SENTRY_DSN=

# ── FingerprintJS Pro ────────────────────────────────────
# Browser API key (public — safe to expose to frontend)
FINGERPRINT_API_KEY=
# Custom subdomain proxy (avoids ad blockers). Leave empty for default CDN.
FINGERPRINT_ENDPOINT=https://finger.arthuragrelli.com

# ── Meta Conversions API (CAPI) ────────────────────────
# Pixel ID from Events Manager > Settings
META_PIXEL_ID=
# System User access token with ads_management permission
META_CAPI_ACCESS_TOKEN=
# Test Event Code from Events Manager > Test Events (dev/staging only)
# When set, events go to Test Events tab instead of real attribution
META_CAPI_TEST_EVENT_CODE=
# App secret (for webhook signature verification)
META_APP_SECRET=
# Webhook verify token (pre-shared secret for webhook handshake)
META_WEBHOOK_VERIFY_TOKEN=

# ── Chatwoot ────────────────────────────────────────────
# Website token from Chatwoot inbox settings
CHATWOOT_WEBSITE_TOKEN=
# Base URL (default: https://app.chatwoot.com)
CHATWOOT_BASE_URL=https://app.chatwoot.com

# ── AWS S3 / CloudFront (production only) ──────────────
# AWS_STORAGE_BUCKET_NAME=
# AWS_CLOUDFRONT_DOMAIN=
