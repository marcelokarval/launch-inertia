# =============================================================================
# Launch Inertia - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# ── Environment ─────────────────────────────────────────
# APP_ENV values: local, development, testing, staging, production
APP_ENV=local
DJANGO_ENV=development
DEBUG=True

# ── Security ────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-in-production

# Comma-separated
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8844,http://localhost:3344

# ── Database (PostgreSQL) ───────────────────────────────
DB_NAME=launch_inertia
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=0

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1

# ── Email (AWS SES in production) ──────────────────────
# In development, emails go to console by default
DEFAULT_FROM_EMAIL=noreply@launch.app
AWS_SES_REGION_NAME=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Google OAuth (django-allauth) ──────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=

# ── Stripe / dj-stripe ─────────────────────────────────
STRIPE_LIVE_MODE=False
STRIPE_TEST_SECRET_KEY=sk_test_your_key
STRIPE_TEST_PUBLIC_KEY=pk_test_your_key
STRIPE_LIVE_SECRET_KEY=
STRIPE_LIVE_PUBLIC_KEY=
DJSTRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Logging ─────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ── Vite Dev Server ────────────────────────────────────
VITE_DEV_URL=http://localhost:3344

# ── Sentry (production only) ───────────────────────────
# SENTRY_DSN=

# ── FingerprintJS Pro ────────────────────────────────────
# Browser API key (public — safe to expose to frontend)
FINGERPRINT_API_KEY=
# Custom subdomain proxy (avoids ad blockers). Leave empty for default CDN.
FINGERPRINT_ENDPOINT=https://finger.arthuragrelli.com

# ── AWS S3 / CloudFront (production only) ──────────────
# AWS_STORAGE_BUCKET_NAME=
# AWS_CLOUDFRONT_DOMAIN=
